APP_ENV=dev
EXECUTION_MODE=paper
CONFIG_DIR=configs
DATA_DIR=data

DEFAULT_SYMBOLS=AAPL,MSFT,NVDA
TOKEN_BUDGET=low
MAX_SPECIALISTS_PER_CYCLE=3

# Optional default provider override.
# Supported examples:
# QUANTER_DATA_PROVIDER=deterministic
# QUANTER_DATA_PROVIDER=polygon_market_data
# QUANTER_DATA_PROVIDER=fmp_market_data
QUANTER_DATA_PROVIDER=deterministic

# Optional kwargs passed into create_provider(...) when QUANTER_DATA_PROVIDER is set.
# Example:
# QUANTER_PROVIDER_API_KEY=your_api_key
# QUANTER_PROVIDER_ROOT=/absolute/path/to/local/files

# Live data provider credentials.
POLYGON_API_KEY=
FMP_API_KEY=
FRED_API_KEY=

# SEC requires a descriptive user agent with contact info.
SEC_USER_AGENT=QuanterSwarm research@example.com
